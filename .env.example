# ═══════════════════════════════════════════════════════
# Studio Post — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments.
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# Firebase Client SDK (NEXT_PUBLIC_ = exposed to browser)
# Get from: Firebase Console → Project Settings → Your Apps → Web
# ───────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ───────────────────────────────────────────────────────
# Firebase Admin SDK (server-side only — NEVER exposed)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# ───────────────────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ───────────────────────────────────────────────────────
# AI APIs (server-side — system keys for free/paid tiers)
# Users on "own_keys" tier provide their own keys instead
# ───────────────────────────────────────────────────────
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPEN_API_KEY=

# ───────────────────────────────────────────────────────
# Optional: Stripe (only for paid tier billing)
# ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ───────────────────────────────────────────────────────
# Optional: Meta (Facebook/Instagram) Integration
# Required only if you want to publish posts directly
# See README "Meta (Facebook/Instagram) Setup" section
# ───────────────────────────────────────────────────────
# NEXT_PUBLIC_META_APP_ID=               # Meta App ID (exposed to browser for OAuth redirect)
# META_APP_ID=                           # Same App ID (server-side, for token exchange)
# META_APP_SECRET=                       # Meta App Secret (server-side only — NEVER expose)

# ───────────────────────────────────────────────────────
# Optional: Encryption key for user tokens
# Must be exactly 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ───────────────────────────────────────────────────────
# ENCRYPTION_KEY=your-32-char-secret-key-here!!!

# ───────────────────────────────────────────────────────
# Optional: App URL (for CORS, emails, etc.)
# ───────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
