# ═══════════════════════════════════════════════════════
# Studio Post — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments.
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# Firebase Client SDK (NEXT_PUBLIC_ = exposed to browser)
# Get from: Firebase Console → Project Settings → Your Apps → Web
# ───────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ───────────────────────────────────────────────────────
# Firebase Admin SDK (server-side only — NEVER exposed)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# ───────────────────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ───────────────────────────────────────────────────────
# AI APIs (server-side — system keys for free/paid tiers)
# Users on "own_keys" tier provide their own keys instead
# ───────────────────────────────────────────────────────
# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPEN_API_KEY=

# ───────────────────────────────────────────────────────
# Optional: Stripe (only for paid tier billing)
# ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ───────────────────────────────────────────────────────
# Optional: Custom limits (defaults shown)
# ───────────────────────────────────────────────────────
# FREE_DAILY_IMAGE_LIMIT=5             # Free tier: 5 images/day
# FREE_DAILY_REFINE_LIMIT=2            # Free tier: 2 refinements/day

# ───────────────────────────────────────────────────────
# Optional: App URL (for CORS, emails, etc.)
# ───────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
